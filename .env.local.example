# =====================================================================
#  GRUPO OHM — variables de entorno
#  Copia este archivo a .env.local y rellena los valores reales.
#  NUNCA subas .env.local al repo (ya está en .gitignore).
# =====================================================================

# ---------- App ----------
# URL pública del sitio. En desarrollo: http://localhost:3000
# En producción: https://pharma-marketing-beta.vercel.app (o el dominio final)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"


# ---------- Mercado Pago (Checkout Pro) ----------
# Credenciales DE PRUEBA proporcionadas por el cliente.
# El access token es SECRETO — solo se usa en el servidor.
# La public key es para el frontend (Bricks, Wallet button, etc.)
#
# Cuando vayan a producción, deben reemplazarse por las credenciales
# de producción de la cuenta real de Sheccid en mercadopago.com.mx
#
MP_ACCESS_TOKEN="PEGA_AQUI_TU_ACCESS_TOKEN_DE_MP"
NEXT_PUBLIC_MP_PUBLIC_KEY="PEGA_AQUI_TU_PUBLIC_KEY_DE_MP"

# Secret para verificar la firma de los webhooks de MP.
# Se configura en mercadopago.com.mx → Tu integración → Webhooks → Secret.
# Por ahora opcional — si está vacío, el webhook acepta sin verificar firma.
MP_WEBHOOK_SECRET=""


# ---------- Envíos ----------
# Provider activo: "standard" usa tarifas planas locales (no requiere API).
# Cambia a "99minutos" cuando tengas las credenciales y el cliente listo.
SHIPPING_PROVIDER="standard"

# 99 minutos — credenciales pendientes (cuando llegue se llena esto)
NINETY_NINE_API_URL="https://api.99minutos.com/v3"
NINETY_NINE_API_KEY=""
NINETY_NINE_API_SECRET=""

# Origen de los envíos (sucursal Tláhuac)
SHIPPING_ORIGIN_NAME="OHM Pharma — Tláhuac"
SHIPPING_ORIGIN_STREET="Av. Tláhuac 2772"
SHIPPING_ORIGIN_CITY="Tláhuac"
SHIPPING_ORIGIN_STATE="CDMX"
SHIPPING_ORIGIN_ZIP="13000"
SHIPPING_ORIGIN_PHONE="+5215555555555"
